generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id             String      @id @default(cuid())
  tipo           TipoActivo
  nombre         String?
  codigoServicio String?
  ubicacion      String?
  propietario    String?
  custodio       String?
  creadoEn       DateTime    @default(now())
  actualizadoEn  DateTime    @updatedAt

  servidor   Servidor?
  red        Red?
  ups        Ups?
  baseDatos  BaseDatos?
  bitacora   Bitacora[]
  vpn        Vpn?
  

  @@index([tipo])
  @@index([nombre])
  @@index([codigoServicio])
}

model Servidor {
  id                   String   @id @default(cuid())
  assetId              String   @unique
  asset                Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  monitoreo            String?
  backup               String?
  ipInterna            String?
  ipGestion            String?
  ipServicio           String?
  ambiente             String?
  tipoServidor         String?
  appSoporta           String?
  vcpu                 Int?
  vramMb               Int?
  sistemaOperativo     String?
  fechaFinSoporte      DateTime?  
  rutasBackup          String?
  contratoQueSoporta   String?
}

model Red {
  id                 String   @id @default(cuid())
  assetId            String   @unique
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  serial             String?
  mac                String?
  modelo             String?
  fechaFinSoporte    DateTime?   
  ipGestion          String?
  estado             String?
  contratoQueSoporta String?
}

model Ups {
  id      String  @id @default(cuid())
  assetId String  @unique
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  serial  String?
  placa   String?
  modelo  String?
  estado  String?
}

model BaseDatos {
  id                 String   @id @default(cuid())
  assetId            String   @unique
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  servidor1          String?
  servidor2          String?
  racScan            String?
  ambiente           String?
  appSoporta         String?
  versionBd          String?
  fechaFinalSoporte  DateTime?   
  contenedorFisico   String?
  contratoQueSoporta String?
}
model Vpn {
  id        String  @id @default(cuid())
  assetId   String  @unique
  asset     Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  conexion  String?   // IP del peer remoto
  fases     String?   // "Phase 2"
  origen    String?   // separado de la celda original
  destino   String?   // separado de la celda original
}

model Bitacora {
  id              String     @id @default(cuid())
  assetId         String
  asset           Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  autor           String
  tipoEvento      TipoEvento
  descripcion     String
  campoModificado String?
  valorAnterior   String?
  valorNuevo      String?
  creadoEn        DateTime   @default(now())

  @@index([assetId])
  @@index([creadoEn])
}

enum TipoActivo {
  SERVIDOR
  RED
  UPS
  BASE_DATOS
  VPN
}

enum TipoEvento {
  IMPORTACION
  CAMBIO_CAMPO
  MANTENIMIENTO
  INCIDENTE
  NOTA
}