generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id              String      @id @default(cuid())
  tipo            TipoActivo
  nombre          String?
  codigoServicio  String?
  ubicacion       String?
  responsable     String?
  creadoEn        DateTime    @default(now())
  actualizadoEn   DateTime    @updatedAt

  servidor        Servidor?
  red             Red?
  ups             Ups?
  baseDatos       BaseDatos?
  bitacora        Bitacora[]

  @@index([tipo])
  @@index([nombre])
  @@index([codigoServicio])
}

model Servidor {
  id               String  @id @default(cuid())
  assetId          String  @unique
  asset            Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  monitoreo        String?
  backup           String?
  ipInterna        String?
  ipGestion        String?
  ipServicio       String?
  ambiente         String?
  tipoServidor     String?
  appSoporta       String?
  vcpu             Int?
  vramMb           Int?
  sistemaOperativo String?
  rutasBackup      String?
}

model Red {
  id         String  @id @default(cuid())
  assetId    String  @unique
  asset      Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  serial     String?
  mac        String?
  modelo     String?
  ipGestion  String?
  estado     String?
}

model Ups {
  id         String  @id @default(cuid())
  assetId    String  @unique
  asset      Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  serial     String?
  placa      String?
  modelo     String?
  estado     String?
}

model BaseDatos {
  id               String  @id @default(cuid())
  assetId          String  @unique
  asset            Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  servidor1        String?
  servidor2        String?
  racScan          String?
  ambiente         String?
  appSoporta       String?
  versionBd        String?
  contenedorFisico String?
}

model Bitacora {
  id              String     @id @default(cuid())
  assetId         String
  asset           Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  autor           String
  tipoEvento      TipoEvento
  descripcion     String
  campoModificado String?
  valorAnterior   String?
  valorNuevo      String?
  creadoEn        DateTime   @default(now())

  @@index([assetId])
  @@index([creadoEn])
}

enum TipoActivo {
  SERVIDOR
  RED
  UPS
  BASE_DATOS
}

enum TipoEvento {
  IMPORTACION
  CAMBIO_CAMPO
  MANTENIMIENTO
  INCIDENTE
  NOTA
}
